---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 6);
---
<section id="journal" class="bg-beige/60 section-pad px-6 lg:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <a
        href="/journal"
        class="inline-block bg-brown text-white px-6 py-3 uppercase tracking-widest text-sm font-semibold mb-8 hover:bg-brown-dark transition-colors"
      >
        Ayla Journal
      </a>
      <h2 class="text-brown text-4xl lg:text-5xl font-display uppercase tracking-wide">
        Stay in the Know
      </h2>
    </div>

    {posts.length === 0 ? (
      <p class="text-brown/60 text-center">Posts coming soon.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <a href={`/journal/${post.slug}`} class="block group">
            <div class="aspect-video bg-beige rounded-lg mb-4 overflow-hidden">
              {post.data.image && (
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              )}
            </div>
            <p class="text-brown/60 text-xs uppercase tracking-wider">
              {post.data.publishDate.toLocaleDateString('en-GB', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </p>
            <h3 class="text-brown text-lg font-semibold mt-2 group-hover:text-olive transition-colors">
              {post.data.title}
            </h3>
          </a>
        ))}
      </div>
    )}
  </div>
</section>
