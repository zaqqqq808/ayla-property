---
const year = new Date().getFullYear();
---
<footer class="bg-cream py-12 px-6 lg:px-12 mt-auto">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
    <a href="/" aria-label="Ayla Property — home">
      <img src="/logo.png" alt="Ayla Property" class="h-10 w-auto" />
    </a>

    <nav class="flex flex-wrap items-center justify-center gap-6 text-sm" aria-label="Footer">
      <a href="/" class="text-brown/70 hover:text-olive transition-colors">Home</a>
      <a href="/journal" class="text-brown/70 hover:text-olive transition-colors">Journal</a>
      <a href="/#methodology" class="text-brown/70 hover:text-olive transition-colors">Methodology</a>
      <a href="/#contact" class="text-brown/70 hover:text-olive transition-colors">Contact</a>
    </nav>

    <div class="text-center md:text-right text-brown/60 text-sm">
      <p>© {year} Ayla Property</p>
      <p class="mt-1">Bali villa investment &amp; property management</p>
    </div>
  </div>
</footer>
