---
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
}

const {
  title = 'Bali Real Estate Investment | High ROI Villas | Ayla Property',
  description = 'Specialist agency and property management for Bali villas and apartments. We help investors find high-ROI properties with end-to-end brokerage support.',
  ogImage = '/og-image.jpg',
  ogType = 'website',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteBase = 'https://aylaproperty.com';

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Ayla Property",
    "url": siteBase,
    "logo": `${siteBase}/logo.png`,
    "description": "Bali real estate investment brokers — we find, vet and negotiate the best villa deals for foreign investors.",
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "customer service",
      "url": "https://calendly.com/ayla-teamoperations/30min"
    },
    "sameAs": []
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Ayla Property",
    "url": siteBase
  }
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonicalURL} />

  <title>{title}</title>

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.url)} />
  <meta property="og:site_name" content="Ayla Property" />
  <meta property="og:locale" content="en_GB" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.url)} />

  <!-- Preconnect performance hints -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700;900&display=swap" rel="stylesheet" />

  <!-- Structured data -->
  {schemas.map(s => (
    <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(s)}</script>`} />
  ))}

  <slot name="head" />
</head>
<body class="bg-white min-h-screen flex flex-col">
  <slot />
</body>
</html>
