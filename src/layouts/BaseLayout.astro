---
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  articleData?: {
    headline: string;
    description: string;
    image: string;
    datePublished: string;
  };
}

const {
  title = 'Bali Real Estate Investment | High ROI Villas | Ayla Property',
  description = 'Specialist agency and property management for Bali villas and apartments. We help investors find high-ROI properties with end-to-end brokerage support.',
  ogImage = '/og-image.jpg',
  noindex = false,
  articleData,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const orgSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Ayla Property",
  "url": "https://aylaproperty.com",
  "logo": "https://aylaproperty.com/logo.png",
  "description": "Bali real estate investment brokers — we find, vet and negotiate the best villa deals for foreign investors.",
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "url": "https://calendly.com/ayla-teamoperations/30min"
  }
});

const websiteSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Ayla Property",
  "url": "https://aylaproperty.com"
});

const articleSchema = articleData ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": articleData.headline,
  "description": articleData.description,
  "image": articleData.image ? new URL(articleData.image, Astro.site).toString() : new URL(ogImage, Astro.site).toString(),
  "datePublished": articleData.datePublished,
  "publisher": {
    "@type": "Organization",
    "name": "Ayla Property",
    "logo": {
      "@type": "ImageObject",
      "url": "https://aylaproperty.com/logo.png"
    }
  }
}) : null;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonicalURL} />
  <meta name="generator" content={Astro.generator} />

  <title>{title}</title>

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.url)} />
  <meta property="og:site_name" content="Ayla Property" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.url)} />

  <!-- Preconnect performance hints -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700;900&display=swap" rel="stylesheet" />

  <!-- Schema: Organization + WebSite -->
  <Fragment set:html={`<script type="application/ld+json">${orgSchema}</script>`} />
  <Fragment set:html={`<script type="application/ld+json">${websiteSchema}</script>`} />

  <!-- Schema: Article (blog posts only) -->
  {articleSchema && <Fragment set:html={`<script type="application/ld+json">${articleSchema}</script>`} />}
</head>
<body class="bg-white min-h-screen flex flex-col">
  <slot />
</body>
</html>
