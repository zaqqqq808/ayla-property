---
import CalendlyButton from './CalendlyButton.astro';
---
<section class="bg-gold relative overflow-hidden pt-32 pb-20 lg:pt-40 lg:pb-32 px-6 lg:px-12">
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
    <div class="space-y-6">
      <img
        src="/logo.png"
        alt="Ayla Property"
        class="h-32 lg:h-44 w-auto -ml-1"
        width="320"
        height="200"
      />
      <p class="text-olive uppercase tracking-widest text-sm lg:text-base font-semibold">
        Bali Villas &amp; Apartments
      </p>
      <h1 class="text-brown text-4xl md:text-5xl lg:text-6xl font-display leading-tight uppercase">
        Specialist Agency<br />and Property Management
      </h1>
      <div class="pt-4">
        <CalendlyButton text="Schedule a Call" variant="olive" />
      </div>
    </div>

    <div class="relative">
      <!-- Replace /images/hero-villa.jpg with your villa image (e.g. the existing Bali villa shot) -->
      <img
        src="/images/hero-villa.jpg"
        alt="Luxury Bali villa with infinity pool overlooking the ocean at sunset"
        class="rounded-2xl shadow-2xl w-full h-auto"
        loading="eager"
        width="1200"
        height="900"
      />
    </div>
  </div>
</section>
