---
import CalendlyButton from './CalendlyButton.astro';

const steps = [
  {
    number: '01',
    title: 'Consultation',
    description:
      "We start with a deep dive into your goals — budget, ROI expectations, lifestyle preferences, and risk tolerance — so we understand exactly what you're looking for in Bali.",
    featured: false,
  },
  {
    number: '02',
    title: 'Curation',
    description:
      'We access our huge database of Bali developers to find the offers that match your goals. So far, already better than 90% of Bali agencies.',
    featured: false,
  },
  {
    number: '03',
    title: 'Research and Negotiation',
    description:
      'We shortlist the favourites and then perform rigourous research on the reputation, quality and reviews of the chosen developers. We then negotiate on your behalf to get the best deal.',
    featured: true,
  },
];

const youtubeId = 'T7At3AGvuHo';
---
<section id="methodology" class="bg-white pt-20 pb-10 lg:pt-32 lg:pb-12 px-6 lg:px-12">
  <div class="max-w-5xl mx-auto">
    <div class="aspect-video rounded-2xl overflow-hidden shadow-lg mb-12 bg-beige">
      <iframe
        class="w-full h-full"
        src={`https://www.youtube-nocookie.com/embed/${youtubeId}`}
        title="Ayla Property — Our Method"
        loading="lazy"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>

    <div class="text-center mb-12">
      <h2 class="sr-only">Our Method</h2>
      <p class="text-gold-dark uppercase tracking-widest text-sm font-semibold mb-2">
        Our Method
      </p>
      <p class="italic text-brown/80 text-lg">
        First, watch the video. It's only 1 minute long…
      </p>
    </div>

    <!-- Steps: 2x2 on mobile, 01+02 top row, 03 full width bottom row -->
    <div class="grid grid-cols-2 lg:grid-cols-3 gap-4">
      {steps.map((step) => (
        <div class:list={[
          "rounded-xl p-4 lg:p-6 text-center border",
          step.featured
            ? "col-span-2 lg:col-span-1 bg-brown border-brown text-white"
            : "bg-cream border-beige"
        ]}>
          <p class:list={["text-lg lg:text-2xl font-display italic mb-1 lg:mb-2", step.featured ? "text-gold" : "text-gold-dark"]}>
            {step.number}
          </p>
          <h3 class:list={["text-xs lg:text-base uppercase tracking-widest font-display mb-2 lg:mb-3", step.featured ? "text-white" : "text-brown"]}>
            {step.title}
          </h3>
          <p class:list={["text-xs lg:text-sm leading-relaxed", step.featured ? "text-white/85" : "text-brown/75"]}>
            {step.description}
          </p>
        </div>
      ))}
    </div>

    <div class="text-center mt-10 mb-0">
      <CalendlyButton text="Book a Call" variant="olive" />
    </div>
  </div>
</section>

<Fragment set:html={`<script type="application/ld+json">${JSON.stringify({
  "@context": "https://schema.org",
  "@type": "VideoObject",
  "name": "How Ayla Property Works — Our Method",
  "description": "A 1-minute overview of how Ayla Property finds, vets and negotiates Bali real estate deals for foreign investors.",
  "thumbnailUrl": "https://img.youtube.com/vi/T7At3AGvuHo/maxresdefault.jpg",
  "uploadDate": "2025-01-01",
  "duration": "PT1M",
  "embedUrl": "https://www.youtube-nocookie.com/embed/T7At3AGvuHo",
  "url": "https://www.youtube.com/watch?v=T7At3AGvuHo",
  "publisher": {
    "@type": "Organization",
    "name": "Ayla Property",
    "url": "https://www.aylaproperty.com"
  }
})}</script>`} />
