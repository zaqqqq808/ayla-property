---
const team = [
  {
    name: 'Silvia',
    role: 'President',
    image: '/images/team-silvia.jpg',
  },
  {
    name: 'Zaq',
    role: 'Vice President',
    image: '/images/team-zaq.jpg',
  },
  {
    name: 'Willy',
    role: 'Real Estate Agent',
    image: '/images/team-willy.jpg',
  },
  {
    name: 'Jackie',
    role: 'AYLA team mascot',
    image: '/images/team-jackie.jpg',
  },
];
---
<section id="team" class="bg-cream section-pad px-6 lg:px-12">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-brown text-4xl lg:text-5xl text-center font-display uppercase mb-16 tracking-wide">
      Meet the Team
    </h2>

    <!-- Desktop: 4-column grid -->
    <div class="hidden lg:grid grid-cols-4 gap-6">
      {team.map((member) => (
        <article class="bg-white/60 border border-beige rounded-lg overflow-hidden text-center transition-transform hover:-translate-y-1 hover:shadow-lg">
          <div class="aspect-square bg-beige/40 flex items-center justify-center relative">
            <img
              src={member.image}
              alt={`Photo of ${member.name}, ${member.role}`}
              class="w-full h-full object-cover"
              loading="lazy"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <span class="absolute inset-0 hidden items-center justify-center text-beige text-7xl font-display" aria-hidden="true">
              {member.name[0]}
            </span>
          </div>
          <div class="p-6">
            <h3 class="text-brown text-xl font-display uppercase tracking-wide">{member.name}</h3>
            <p class="text-brown/60 text-sm italic mt-1">{member.role}</p>
          </div>
        </article>
      ))}
    </div>

    <!-- Mobile: swipeable carousel -->
    <div class="lg:hidden relative">
      <div
        id="team-carousel"
        class="flex gap-4 overflow-x-auto snap-x snap-mandatory pb-4 -mx-6 px-6"
        style="scrollbar-width: none; -ms-overflow-style: none;"
      >
        {team.map((member) => (
          <article class="flex-none w-[72vw] max-w-[280px] snap-center bg-white/60 border border-beige rounded-lg overflow-hidden text-center">
            <div class="aspect-square bg-beige/40 flex items-center justify-center relative">
              <img
                src={member.image}
                alt={`Photo of ${member.name}, ${member.role}`}
                class="w-full h-full object-cover"
                loading="lazy"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
              />
              <span class="absolute inset-0 hidden items-center justify-center text-beige text-7xl font-display" aria-hidden="true">
                {member.name[0]}
              </span>
            </div>
            <div class="p-5">
              <h3 class="text-brown text-lg font-display uppercase tracking-wide">{member.name}</h3>
              <p class="text-brown/60 text-sm italic mt-1">{member.role}</p>
            </div>
          </article>
        ))}
      </div>

      <!-- Dot indicators -->
      <div id="team-dots" class="flex justify-center gap-2 mt-4">
        {team.map((_, i) => (
          <button
            class="team-dot w-2 h-2 rounded-full bg-beige transition-all duration-300"
            data-index={i}
            aria-label={`Go to slide ${i + 1}`}
          />
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  #team-carousel::-webkit-scrollbar { display: none; }
</style>

<script>
  const carousel = document.getElementById('team-carousel');
  const dots     = document.querySelectorAll('.team-dot');

  function updateDots(index: number) {
    dots.forEach((dot, i) => {
      dot.classList.toggle('bg-brown',   i === index);
      dot.classList.toggle('w-4',        i === index);
      dot.classList.toggle('bg-beige',   i !== index);
      dot.classList.toggle('w-2',        i !== index);
    });
  }

  // Update dots on scroll
  carousel?.addEventListener('scroll', () => {
    if (!carousel) return;
    const cardWidth = (carousel.firstElementChild as HTMLElement)?.offsetWidth ?? 1;
    const index = Math.round(carousel.scrollLeft / (cardWidth + 16));
    updateDots(index);
  }, { passive: true });

  // Dot click → scroll to card
  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      if (!carousel) return;
      const cardWidth = (carousel.firstElementChild as HTMLElement)?.offsetWidth ?? 0;
      carousel.scrollTo({ left: i * (cardWidth + 16), behavior: 'smooth' });
    });
  });

  updateDots(0);
</script>
