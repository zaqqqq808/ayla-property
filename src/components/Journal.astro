---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);
---
<section id="journal" class="bg-beige/60 section-pad px-6 lg:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-gold-dark uppercase tracking-widest text-sm font-semibold mb-3">Ayla Journal</p>
      <h2 class="text-brown text-4xl lg:text-5xl font-display uppercase tracking-wide">
        Stay in the Know
      </h2>
    </div>

    {posts.length === 0 ? (
      <p class="text-brown/60 text-center">Posts coming soon.</p>
    ) : (
      <>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <a href={`/journal/${post.slug}`} class="block group">
              <div class="aspect-video bg-beige rounded-lg mb-4 overflow-hidden">
                {post.data.image && (
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                )}
              </div>
              <p class="text-brown/60 text-xs uppercase tracking-wider">
                {post.data.publishDate.toLocaleDateString('en-GB', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </p>
              <h3 class="text-brown text-lg font-semibold mt-2 group-hover:text-olive transition-colors">
                {post.data.title}
              </h3>
            </a>
          ))}
        </div>

        <div class="text-center mt-12">
          <a
            href="/journal"
            class="inline-flex items-center gap-2 text-brown border border-brown px-8 py-3 uppercase tracking-widest text-sm font-semibold hover:bg-brown hover:text-white transition-colors rounded"
          >
            View All Articles
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </>
    )}
  </div>
</section>
