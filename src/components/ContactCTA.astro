---
import CalendlyButton from './CalendlyButton.astro';
---
<section id="contact" class="bg-brown text-white section-pad px-6 lg:px-12">
  <div class="max-w-3xl mx-auto text-center">
    <p class="text-gold uppercase tracking-widest text-sm font-semibold mb-4">Get Started</p>
    <h2 class="text-4xl lg:text-5xl font-display uppercase mb-6 tracking-wide">Ready to Invest?</h2>
    <p class="text-white/80 text-lg mb-10 leading-relaxed">
      Book a free 30-minute call with our team. No pressure, no obligation. Just honest advice on whether Bali is the right move for you.
    </p>

    <CalendlyButton text="Book Your Free 30-Min Call" variant="olive" />
    <p class="text-white/50 text-sm mt-4">Free · No obligation · We reply within 24 hours</p>
  </div>
</section>
