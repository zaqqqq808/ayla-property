---
import CalendlyButton from './CalendlyButton.astro';
---
<div
  id="sticky-cta"
  class="fixed bottom-6 right-6 z-50 opacity-0 translate-y-4 transition-all duration-300 pointer-events-none"
>
  <CalendlyButton text="📞 Book a Free Call" variant="brown" />
</div>

<script>
  const sticky = document.getElementById('sticky-cta');
  const hero = document.querySelector('section');

  const observer = new IntersectionObserver(
    ([entry]) => {
      if (!sticky) return;
      if (!entry.isIntersecting) {
        sticky.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
      } else {
        sticky.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
      }
    },
    { threshold: 0.1 }
  );

  if (hero) observer.observe(hero);
</script>
