---
// InstagramFeed.astro
// Live feed pulled from Instagram Graph API via /api/instagram (Vercel serverless).
// Falls back to static placeholder images if token is not yet configured.

const igUrl = 'https://www.instagram.com/aylaproperty/';

const fallbackPosts = [
  { src: '/images/instagram/post-1.jpg', alt: 'Ayla Property Instagram post 1' },
  { src: '/images/instagram/post-2.jpg', alt: 'Ayla Property Instagram post 2' },
  { src: '/images/instagram/post-3.jpg', alt: 'Ayla Property Instagram post 3' },
  { src: '/images/instagram/post-4.jpg', alt: 'Ayla Property Instagram post 4' },
];
---

<section class="bg-white py-16 px-0 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 mb-10 flex flex-col sm:flex-row items-center justify-between gap-4">
    <div>
      <p class="text-gold-dark uppercase tracking-widest text-sm font-semibold mb-2">On the Ground in Bali</p>
      <h2 class="text-brown text-3xl lg:text-4xl font-display uppercase tracking-wide">Follow Us on Instagram</h2>
    </div>
    <a
      href={igUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-2 text-brown/60 hover:text-olive transition-colors text-sm uppercase tracking-widest font-semibold shrink-0"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
        <circle cx="12" cy="12" r="4"/>
        <circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" stroke="none"/>
      </svg>
      @aylaproperty
    </a>
  </div>

  <!-- Swipeable carousel — populated by client-side JS from /api/instagram -->
  <div class="ig-track" id="ig-track" data-ig-url={igUrl}>

    <!-- Skeleton placeholders shown while JS fetches live data -->
    <div class="ig-skeleton" id="ig-skeleton">
      {[1,2,3,4].map(() => (
        <div class="ig-slide ig-slide--skeleton" aria-hidden="true">
          <div class="ig-skeleton-inner" />
        </div>
      ))}
    </div>

    <!-- Fallback markup (hidden by default, shown if API fails) -->
    <div class="ig-fallback" id="ig-fallback" style="display:none">
      {fallbackPosts.map((post) => (
        <a href={igUrl} target="_blank" rel="noopener noreferrer" class="ig-slide" aria-label="View on Instagram">
          <img src={post.src} alt={post.alt} loading="lazy" draggable="false" />
        </a>
      ))}
    </div>

    <!-- Live posts injected here by JS -->
    <div class="ig-live" id="ig-live" style="display:none"></div>

  </div>
</section>

<style>
  .ig-track {
    display: flex;
    gap: 6px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0 max(24px, calc((100vw - 1280px) / 2 + 24px));
    cursor: grab;
  }

  .ig-track::-webkit-scrollbar { display: none; }
  .ig-track:active { cursor: grabbing; }

  /* Skeleton & live containers sit side-by-side in the flex row */
  .ig-skeleton,
  .ig-fallback,
  .ig-live {
    display: contents; /* children participate directly in the flex layout */
  }

  .ig-slide {
    flex-shrink: 0;
    width: 240px;
    aspect-ratio: 9 / 16;
    scroll-snap-align: start;
    border-radius: 10px;
    overflow: hidden;
    display: block;
    position: relative;
    background: #f0ebe4;
  }

  .ig-slide img,
  .ig-slide video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .ig-slide:hover img,
  .ig-slide:hover video {
    transform: scale(1.04);
  }

  /* Skeleton shimmer */
  .ig-slide--skeleton .ig-skeleton-inner {
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, #ede8e2 25%, #e0d8cf 50%, #ede8e2 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }

  @keyframes shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* Play icon overlay for videos */
  .ig-play-icon {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .ig-play-icon svg {
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.5));
    opacity: 0.85;
  }

  @media (max-width: 768px) {
    .ig-slide { width: 180px; }
  }
</style>

<script>
  const igUrl = document.getElementById('ig-track')?.dataset.igUrl || 'https://www.instagram.com/aylaproperty/';

  async function loadInstagramFeed() {
    const skeleton = document.getElementById('ig-skeleton');
    const fallback  = document.getElementById('ig-fallback');
    const live      = document.getElementById('ig-live');
    if (!live) return;

    try {
      const res = await fetch('/api/instagram', { cache: 'no-store' });
      const data = await res.json();

      if (!res.ok || data.fallback || !data.data?.length) {
        throw new Error(data.error || 'No posts returned');
      }

      // Build live post cards
      const posts = data.data.slice(0, 6);
      const html = posts.map((post: any) => {
        const isVideo = post.media_type === 'VIDEO';
        const imgSrc  = isVideo ? post.thumbnail_url : post.media_url;
        const caption = post.caption ? post.caption.replace(/"/g, '&quot;').slice(0, 125) : 'Ayla Property — Bali real estate';
        const playIcon = isVideo
          ? `<div class="ig-play-icon">
               <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                 <circle cx="20" cy="20" r="20" fill="rgba(0,0,0,0.35)"/>
                 <polygon points="16,12 30,20 16,28" fill="white"/>
               </svg>
             </div>`
          : '';
        return `
          <a href="${post.permalink}" target="_blank" rel="noopener noreferrer"
             class="ig-slide" aria-label="${caption}">
            <img src="${imgSrc}" alt="${caption}" loading="lazy" draggable="false" />
            ${playIcon}
          </a>`;
      }).join('');

      live.innerHTML = html;
      live.style.display = 'contents';

      // Hide skeleton
      if (skeleton) (skeleton as HTMLElement).style.display = 'none';

    } catch (err) {
      console.warn('[InstagramFeed] API unavailable, showing fallback:', err);
      // Show static fallback images
      if (skeleton) (skeleton as HTMLElement).style.display = 'none';
      if (fallback)  (fallback as HTMLElement).style.display = 'contents';
    }
  }

  loadInstagramFeed();

  // Drag-to-scroll on desktop
  const track = document.getElementById('ig-track') as HTMLElement;
  if (track) {
    let isDown = false, startX = 0, scrollLeft = 0;
    track.addEventListener('mousedown', (e) => {
      isDown = true;
      startX = e.pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
    });
    track.addEventListener('mouseleave', () => { isDown = false; });
    track.addEventListener('mouseup',    () => { isDown = false; });
    track.addEventListener('mousemove',  (e) => {
      if (!isDown) return;
      e.preventDefault();
      track.scrollLeft = scrollLeft - (e.pageX - track.offsetLeft - startX) * 1.5;
    });
  }
</script>
