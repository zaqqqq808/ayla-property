---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Hero from '@/components/Hero.astro';
import StatsBar from '@/components/StatsBar.astro';
import WhyBali from '@/components/WhyBali.astro';
import PropertyCarousel from '@/components/PropertyCarousel.astro';
import Methodology from '@/components/Methodology.astro';
import Testimonials from '@/components/Testimonials.astro';
import Team from '@/components/Team.astro';
import FAQ from '@/components/FAQ.astro';
import Journal from '@/components/Journal.astro';
import ContactCTA from '@/components/ContactCTA.astro';
import InstagramFeed from '@/components/InstagramFeed.astro';
import Footer from '@/components/Footer.astro';
import StickyButton from '@/components/StickyButton.astro';
---
<BaseLayout
  title="Bali Real Estate Investment | 15%+ Rental Yields | Ayla Property"
  description="Earn 15%+ rental yields investing in Bali property. Ayla Property finds, vets and negotiates the best Bali villa deals for foreign investors. Book a free call."
>
  <Fragment slot="head">
    <link rel="preload" as="image" href="/images/hero-villa.jpg" fetchpriority="high" />
  </Fragment>
  <Header />
  <main>
    <Hero />
    <StatsBar />
    <WhyBali />
    <PropertyCarousel />
    <Methodology />
    <Testimonials />
    <Team />
    <FAQ />
    <Journal />
    <InstagramFeed />
    <ContactCTA />
  </main>
  <Footer />
  <StickyButton />
</BaseLayout>
