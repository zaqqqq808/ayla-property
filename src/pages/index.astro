---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Hero from '@/components/Hero.astro';
import StatsBar from '@/components/StatsBar.astro';
import WhyBali from '@/components/WhyBali.astro';
import PropertyCarousel from '@/components/PropertyCarousel.astro';
import Methodology from '@/components/Methodology.astro';
import Testimonials from '@/components/Testimonials.astro';
import Team from '@/components/Team.astro';
import FAQ from '@/components/FAQ.astro';
import Journal from '@/components/Journal.astro';
import ContactCTA from '@/components/ContactCTA.astro';
import Footer from '@/components/Footer.astro';
import StickyButton from '@/components/StickyButton.astro';
---
<BaseLayout
  title="Buy Property in Bali | 15%+ Yields | Ayla Property"
  description="Looking to buy property in Bali? We specialise in Bali property investment, finding villas with 15%+ rental yields for foreign buyers. Free consultation."
>
  <Fragment slot="head">
    <link rel="preload" as="image" href="/images/hero-villa.jpg" fetchpriority="high" />
  </Fragment>
  <Header />
  <main>
    <Hero />
    <StatsBar />
    <WhyBali />
    <PropertyCarousel />
    <Methodology />
    <Testimonials />
    <Team />
    <FAQ />
    <Journal />
    <ContactCTA />
  </main>
  <Footer />
  <StickyButton />
</BaseLayout>
