# Copy this file to .env (locally) or add as Environment Variables in Vercel.

# Resend (free tier covers 100 emails/day) — used for the contact form on /
# Sign up at https://resend.com, add your domain, paste the API key here.
# OPTIONAL: if you only want Calendly bookings (no contact form), you can leave this blank.
RESEND_API_KEY=

# Where contact form enquiries are emailed to.
CONTACT_TO_EMAIL=zaq@aylaproperty.com

# The "from" address used when sending. Must be on a domain you've verified in Resend.
CONTACT_FROM_EMAIL=noreply@aylaproperty.com

# Your Calendly username/event URL — used by all "Schedule a Call" buttons.
PUBLIC_CALENDLY_URL=https://calendly.com/aylaproperty
